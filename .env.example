# OCR Provider: google-vision | mock
OCR_PROVIDER=mock

# Google Cloud Vision (OCR_PROVIDER=google-vision 일 때)
GOOGLE_CLOUD_VISION_API_KEY=

# AI Provider: openai | mock
AI_PROVIDER=mock

# OpenAI (AI_PROVIDER=openai 일 때)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# RAG (추후 벡터 DB 연동)
RAG_ENABLED=false
VECTOR_DB_URL=
VECTOR_DB_API_KEY=
