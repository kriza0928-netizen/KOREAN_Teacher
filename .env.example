# OCR Provider: google-vision (필수)
OCR_PROVIDER=google-vision

# Google Cloud Vision (필수)
GOOGLE_CLOUD_VISION_API_KEY=

# AI Provider: openai (분석 생성 시 필수)
AI_PROVIDER=openai

# OpenAI (AI_PROVIDER=openai 일 때)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# RAG (추후 벡터 DB 연동)
RAG_ENABLED=false
VECTOR_DB_URL=
VECTOR_DB_API_KEY=
